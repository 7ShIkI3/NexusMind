{
  "name": "nexusmind-desktop",
  "version": "1.0.0",
  "description": "NexusMind Desktop Application",
  "main": "electron/main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder",
    "build:win": "electron-builder --win",
    "build:linux": "electron-builder --linux",
    "dev": "concurrently \"cd ../frontend && npm run dev\" \"wait-on http://localhost:3000 && electron .\""
  },
  "dependencies": {
    "electron-store": "^8.2.0"
  },
  "devDependencies": {
    "electron": "^31.0.0",
    "electron-builder": "^24.13.3",
    "concurrently": "^8.2.2",
    "wait-on": "^7.2.0"
  },
  "build": {
    "appId": "com.nexusmind.app",
    "productName": "NexusMind",
    "directories": {
      "output": "dist"
    },
    "files": [
      "electron/**/*",
      "node_modules/**/*"
    ],
    "win": {
      "target": [{ "target": "nsis", "arch": ["x64"] }],
      "icon": "assets/icon.ico"
    },
    "linux": {
      "target": [{ "target": "AppImage", "arch": ["x64"] }, { "target": "deb" }],
      "icon": "assets/icon.png",
      "category": "Utility"
    },
    "mac": {
      "target": [{ "target": "dmg" }],
      "icon": "assets/icon.icns"
    }
  }
}
