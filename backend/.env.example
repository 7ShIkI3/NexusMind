# NexusMind Backend Configuration
# Copy this file to .env and fill in your values
# REQUIRED: All values must be set before deployment

# App Security (REQUIRED)
DEBUG=false
SECRET_KEY=generate-a-secure-random-key-min-32-chars-change-in-production
CORS_ORIGINS=localhost:3000,localhost:3001

# Rate Limiting & Size Limits
RATE_LIMIT_PER_MINUTE=100
MAX_FILE_SIZE=10485760
MAX_REQUEST_SIZE=10485760
MAX_TOOL_RESULT_SIZE=5242880

# AI Providers
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_DEFAULT_MODEL=llama3

OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_DEFAULT_MODEL=gpt-4o

ANTHROPIC_API_KEY=
ANTHROPIC_DEFAULT_MODEL=claude-3-5-sonnet-20241022

GOOGLE_API_KEY=
GOOGLE_DEFAULT_MODEL=gemini-1.5-pro

ABACUS_API_KEY=
ABACUS_BASE_URL=https://api.abacus.ai/v0

# RAG
EMBEDDING_MODEL=all-MiniLM-L6-v2
RAG_CHUNK_SIZE=512
RAG_CHUNK_OVERLAP=64
RAG_TOP_K=5

# Database
DATABASE_URL=sqlite:///./data/nexusmind.db
CHROMA_DB_PATH=./data/chroma_db

# Extensions
EXTENSIONS_PATH=./extensions

# Routines
ROUTINE_CHECK_INTERVAL=60
